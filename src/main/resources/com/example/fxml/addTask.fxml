<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.controllers.AddTaskController"
      spacing="20" 
      alignment="CENTER" 
      style="-fx-padding:30; -fx-background-color:white;"
      prefWidth="400" prefHeight="450">

    <Label text="Create New Task"
           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1e293b;"/>

    <Separator prefWidth="300"/>

    <TextField fx:id="taskNameField"
               promptText="Task Name *"
               prefWidth="300"
               style="-fx-padding:10; -fx-background-radius:5;"/>

    <ComboBox fx:id="assignedBox"
              promptText="Assign to Team Member"
              prefWidth="300"
              style="-fx-padding:5; -fx-background-radius:5;"/>

    <ComboBox fx:id="priorityBox"
              promptText="Priority"
              prefWidth="300"
              style="-fx-padding:5; -fx-background-radius:5;"/>

    <ComboBox fx:id="statusBox"
              promptText="Status"
              prefWidth="300"
              style="-fx-padding:5; -fx-background-radius:5;"/>

    <DatePicker fx:id="deadlinePicker"
                promptText="Deadline"
                prefWidth="300"
                style="-fx-padding:5; -fx-background-radius:5;"/>

    <HBox spacing="15" alignment="CENTER">
        <Button text="Cancel"
                onAction="#handleCancel"
                style="-fx-background-color:#f1f5f9; -fx-padding:10 25; -fx-background-radius:5; -fx-cursor:hand;"/>
        
        <Button text="Add Task"
                onAction="#addTask"
                style="-fx-background-color:#6366f1; -fx-text-fill:white; -fx-padding:10 25; -fx-background-radius:5; -fx-font-weight:bold; -fx-cursor:hand;"/>
    </HBox>

</VBox>