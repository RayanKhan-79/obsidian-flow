<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.controllers.SettingsController"
            style="-fx-background-color:#f5f7fb;">

    <!-- LEFT SIDEBAR (Same as Dashboard) -->
    <left>
        <VBox spacing="20" prefWidth="220" style="-fx-background-color:#1e293b; -fx-padding:25;">
            <Label text="TaskFlow" style="-fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold;"/>
            <Separator/>
            <Button fx:id="dashboardBtn" text="Dashboard" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="projectsBtn" text="Projects" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="tasksBtn" text="Tasks" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="teamBtn" text="Team" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="reportsBtn" text="Reports" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="settingsBtn" text="Settings" style="-fx-background-color:#334155; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Button fx:id="logoutBtn" text="Logout" style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color:white; -fx-padding:15;">
            <Label text="Settings" style="-fx-font-size:20px; -fx-font-weight:bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label text="🔔" style="-fx-font-size:18px; -fx-cursor:hand;"/>
            <Label text="👤 John Doe" style="-fx-font-weight:bold; -fx-cursor:hand;"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="25" style="-fx-padding:30;">
            
            <TabPane fx:id="settingsTabPane" tabClosingPolicy="UNAVAILABLE" prefHeight="400">
                
                <!-- Profile Tab -->
                <Tab text="Profile">
                    <VBox spacing="20" style="-fx-padding:20;">
                        <Label text="Personal Information" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                        
                        <GridPane hgap="20" vgap="15">
                            <Label text="Full Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="fullNameField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250"/>
                            
                            <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250"/>
                        </GridPane>
                        
                        <Button fx:id="saveProfileBtn" text="Save Changes" 
                                style="-fx-background-color:#6366f1; -fx-text-fill:white; -fx-padding:10 20; -fx-background-radius:5; -fx-cursor:hand;" 
                                maxWidth="150"/>
                    </VBox>
                </Tab>
                
                <!-- Security Tab -->
                <Tab text="Security">
                    <VBox spacing="20" style="-fx-padding:20;">
                        <Label text="Change Password" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                        
                        <GridPane hgap="20" vgap="15">
                            <Label text="Current Password:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <PasswordField fx:id="currentPasswordField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250"/>
                            
                            <Label text="New Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <PasswordField fx:id="newPasswordField" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250"/>
                            
                            <Label text="Confirm Password:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <PasswordField fx:id="confirmPasswordField" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="250"/>
                        </GridPane>
                        
                        <Button fx:id="changePasswordBtn" text="Change Password" 
                                style="-fx-background-color:#6366f1; -fx-text-fill:white; -fx-padding:10 20; -fx-background-radius:5; -fx-cursor:hand;" 
                                maxWidth="150"/>
                    </VBox>
                </Tab>
                
                <!-- Preferences Tab -->
                <Tab text="Preferences">
                    <VBox spacing="20" style="-fx-padding:20;">
                        <Label text="Application Settings" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                        
                        <GridPane hgap="20" vgap="15">
                            <Label text="Theme:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="themeComboBox" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>
                            
                            <Label text="Notifications:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" spacing="5">
                                <CheckBox fx:id="emailNotificationsCheck" text="Email Notifications"/>
                                <CheckBox fx:id="pushNotificationsCheck" text="Push Notifications"/>
                            </VBox>
                        </GridPane>
                        
                        <Button fx:id="savePreferencesBtn" text="Save Preferences" 
                                style="-fx-background-color:#6366f1; -fx-text-fill:white; -fx-padding:10 20; -fx-background-radius:5; -fx-cursor:hand;" 
                                maxWidth="150"/>
                    </VBox>
                </Tab>
                
            </TabPane>
            
        </VBox>
    </center>
    
</BorderPane>