<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.controllers.DashboardController"
            style="-fx-background-color:#f5f7fb;">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="20"
              prefWidth="220"
              style="-fx-background-color:#1e293b; -fx-padding:25;">

            <Label text="TaskFlow"
                   style="-fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold;"/>

            <Separator/>

            <Button fx:id="dashboardBtn" text="Dashboard"
                    style="-fx-background-color:#334155; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <!-- ADDED: Projects Button -->
            <Button fx:id="projectsBtn" text="Projects"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Button fx:id="tasksBtn" text="Tasks"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Button fx:id="teamBtn" text="Team"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Button fx:id="reportsBtn" text="Reports"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Button fx:id="settingsBtn" text="Settings"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Pane VBox.vgrow="ALWAYS"/>

            <Button fx:id="logoutBtn" text="Logout"
                    style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20"
              style="-fx-background-color:white; -fx-padding:15;">

            <Label fx:id="dashboardTitle" text="Dashboard"
                   style="-fx-font-size:20px; -fx-font-weight:bold;"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField" promptText="Search tasks..."
                       prefWidth="250"/>

            <Label fx:id="notificationIcon" text="🔔" style="-fx-font-size:18px; -fx-cursor:hand;"/>

            <Label fx:id="userProfileLabel" text="👤 John Doe"
                   style="-fx-font-weight:bold; -fx-cursor:hand;"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="25" style="-fx-padding:30;">

            <!-- STAT CARDS -->
            <HBox spacing="20">

                <VBox spacing="10"
                      style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;"
                      prefWidth="200">
                    <Label text="Total Tasks"/>
                    <Label fx:id="totalTasksValue" text="128"
                           style="-fx-font-size:28px; -fx-font-weight:bold;"/>
                </VBox>

                <VBox spacing="10"
                      style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;"
                      prefWidth="200">
                    <Label text="Completed"/>
                    <Label fx:id="completedTasksValue" text="86"
                           style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#22c55e;"/>
                </VBox>

                <VBox spacing="10"
                      style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;"
                      prefWidth="200">
                    <Label text="Pending"/>
                    <Label fx:id="pendingTasksValue" text="32"
                           style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#f59e0b;"/>
                </VBox>

                <VBox spacing="10"
                      style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;"
                      prefWidth="200">
                    <Label text="Overdue"/>
                    <Label fx:id="overdueTasksValue" text="10"
                           style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#ef4444;"/>
                </VBox>

            </HBox>

            <!-- TASK LIST -->
            <VBox spacing="10"
                  style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;">

                <HBox spacing="10">
                    <Label text="Recent Tasks"
                           style="-fx-font-size:18px; -fx-font-weight:bold;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button fx:id="newTaskButton" text="+ New Task" onAction="#handleNewTask"
                            style="-fx-background-color:#6366f1; -fx-text-fill:white; -fx-cursor:hand; -fx-background-radius:5; -fx-padding:8 15;"/>
                </HBox>

                <TableView fx:id="taskTable" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="taskNameColumn" text="Task Name" prefWidth="250"/>
                        <TableColumn fx:id="priorityColumn" text="Priority" prefWidth="120"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
                        <TableColumn fx:id="dueDateColumn" text="Due Date" prefWidth="150"/>
                    </columns>
                </TableView>

            </VBox>

            <!-- ADDED: Project Completion Label (might be missing) -->
            <Label fx:id="projectCompletionLabel" text="Overall Progress: 67%" 
                   style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#6366f1;"
                   visible="false" managed="false"/>

        </VBox>
    </center>

</BorderPane>