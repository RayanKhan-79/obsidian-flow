<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.frontend.controllers.TeamController"
            style="-fx-background-color:#f5f7fb;">

    <!-- LEFT SIDEBAR (Same as Dashboard) -->
    <left>
        <VBox spacing="20"
              prefWidth="220"
              style="-fx-background-color:#1e293b; -fx-padding:25;">

            <Label text="ObsidianFlow"
                   style="-fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold;"/>

            <Separator/>

            <Button fx:id="dashboardBtn" text="Dashboard"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Button fx:id="projectsBtn" text="Projects"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Button fx:id="tasksBtn" text="Tasks"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Button fx:id="teamBtn" text="Team"
                    style="-fx-background-color:#334155; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Button fx:id="reportsBtn" text="Reports"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Button fx:id="settingsBtn" text="Settings"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>

            <Pane VBox.vgrow="ALWAYS"/>

            <Button fx:id="logoutBtn" text="Logout"
                    style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20"
              style="-fx-background-color:white; -fx-padding:15;">

            <Label text="Team Management"
                   style="-fx-font-size:20px; -fx-font-weight:bold;"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField" 
                       promptText="Search team members..."
                       prefWidth="250"
                       style="-fx-background-radius:5; -fx-padding:8;"/>

            <Label text="🔔" 
                   style="-fx-font-size:18px; -fx-cursor:hand;"/>

            <Label text="👤 John Doe"
                   style="-fx-font-weight:bold; -fx-cursor:hand;"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="25" style="-fx-padding:30;">

            <!-- Header with Add Member Button -->
            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="addMemberButton" 
                        text="+ Add Team Member" 
                        onAction="#handleAddMember"
                        style="-fx-background-color:#6366f1; -fx-text-fill:white; -fx-cursor:hand; -fx-background-radius:5; -fx-padding:10 20; -fx-font-weight:bold;"/>
            </HBox>

            <!-- Team Members Table -->
            <VBox spacing="10"
                  style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;">

                <TableView fx:id="teamTable" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="nameColumn"
                                     text="Name"
                                     prefWidth="200"/>

                        <TableColumn fx:id="emailColumn"
                                     text="Email"
                                     prefWidth="250"/>

                        <TableColumn fx:id="roleColumn"
                                     text="Role"
                                     prefWidth="150"/>

                        <TableColumn fx:id="departmentColumn"
                                     text="Department"
                                     prefWidth="150"/>

                        <TableColumn fx:id="statusColumn"
                                     text="Status"
                                     prefWidth="120"/>

                        <TableColumn fx:id="actionsColumn"
                                     text="Actions"
                                     prefWidth="100"/>
                    </columns>
                </TableView>

            </VBox>

            <!-- Team Stats -->
            <HBox spacing="20" alignment="CENTER">
                <VBox spacing="5" alignment="CENTER"
                      style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10;"
                      prefWidth="150">
                    <Label text="Total Members" style="-fx-text-fill:#64748b;"/>
                    <Label fx:id="totalMembersLabel" text="8" 
                           style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#6366f1;"/>
                </VBox>

                <VBox spacing="5" alignment="CENTER"
                      style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10;"
                      prefWidth="150">
                    <Label text="Active" style="-fx-text-fill:#64748b;"/>
                    <Label fx:id="activeMembersLabel" text="6" 
                           style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#22c55e;"/>
                </VBox>

                <VBox spacing="5" alignment="CENTER"
                      style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10;"
                      prefWidth="150">
                    <Label text="Admins" style="-fx-text-fill:#64748b;"/>
                    <Label fx:id="adminCountLabel" text="2" 
                           style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#f59e0b;"/>
                </VBox>
            </HBox>

        </VBox>
    </center>

</BorderPane>