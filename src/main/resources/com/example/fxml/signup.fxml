<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controllers.SignupController"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background: transparent;">

    <VBox alignment="CENTER" spacing="0">
        <padding>
            <Insets top="40" bottom="40"/>
        </padding>

        <!-- Signup Card -->
        <VBox alignment="CENTER" spacing="25" 
              style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);"
              maxWidth="500">
            
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- Logo and Title -->
            <VBox alignment="CENTER" spacing="15">
                <ImageView fx:id="logoImage" fitHeight="60" fitWidth="60" 
                          preserveRatio="true">
                    <Image url="@../images/logo.png" />
                </ImageView>
                <Label text="Create Account" 
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                <Label text="Join Task Manager today" 
                       style="-fx-font-size: 14px; -fx-text-fill: #718096;"/>
            </VBox>

            <!-- Error Label -->
            <Label fx:id="errorLabel" visible="false" 
                   style="-fx-background-color: #fed7d7; -fx-background-radius: 5; -fx-padding: 10; -fx-text-fill: #c53030;"
                   alignment="CENTER" maxWidth="Infinity"/>

            <!-- Signup Form -->
            <VBox spacing="20">
                <!-- Full Name -->
                <VBox spacing="5">
                    <Label text="Full Name" 
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="fullNameField" promptText="Enter your full name"
                              style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 12; -fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1;"/>
                </VBox>

                <!-- Username -->
                <VBox spacing="5">
                    <Label text="Username" 
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="usernameField" promptText="Choose a username"
                              style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 12; -fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1;"/>
                </VBox>

                <!-- Email -->
                <VBox spacing="5">
                    <Label text="Email Address" 
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="emailField" promptText="Enter your email"
                              style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 12; -fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1;"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="5">
                    <Label text="Password" 
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                    <PasswordField fx:id="passwordField" promptText="Create a password"
                                  style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 12; -fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1;"/>
                    
                    <!-- Password Strength -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Strength:" style="-fx-text-fill: #718096;"/>
                        <Label fx:id="passwordStrengthLabel" text="Not set"/>
                    </HBox>
                    
                    <!-- Password Requirements -->
                    <VBox spacing="3" style="-fx-padding: 10; -fx-background-color: #f7fafc; -fx-background-radius: 5;">
                        <Label fx:id="lengthCheck" text="✗ At least 8 characters"/>
                        <Label fx:id="uppercaseCheck" text="✗ At least one uppercase letter"/>
                        <Label fx:id="lowercaseCheck" text="✗ At least one lowercase letter"/>
                        <Label fx:id="numberCheck" text="✗ At least one number"/>
                    </VBox>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="5">
                    <Label text="Confirm Password" 
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password"
                                  style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 12; -fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1;"/>
                </VBox>

                <!-- Terms and Conditions -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <CheckBox fx:id="termsCheck"/>
                    <Label text="I agree to the" style="-fx-text-fill: #718096;"/>
                    <Hyperlink text="Terms of Service" style="-fx-text-fill: #667eea;"/>
                    <Label text="and" style="-fx-text-fill: #718096;"/>
                    <Hyperlink text="Privacy Policy" style="-fx-text-fill: #667eea;"/>
                </HBox>

                <!-- Signup Button -->
                <StackPane>
                    <Button fx:id="signupButton" text="Create Account" maxWidth="Infinity"
                            onAction="#handleSignup"
                            style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" 
                                     maxWidth="30" maxHeight="30"/>
                </StackPane>

                <!-- Back to Login -->
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Already have an account?" style="-fx-text-fill: #718096;"/>
                    <Button fx:id="backToLoginButton" text="Sign In" 
                            onAction="#handleBackToLogin"
                            style="-fx-background-color: transparent; -fx-text-fill: #667eea; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;"/>
                </HBox>
            </VBox>

            <!-- Footer -->
            <VBox alignment="CENTER" spacing="5">
                <Separator/>
                <Label text="© 2024 Task Manager. All rights reserved." 
                       style="-fx-font-size: 12px; -fx-text-fill: #a0aec0;"/>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>