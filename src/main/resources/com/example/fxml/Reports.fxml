<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.controllers.ReportsController"
            style="-fx-background-color:#f5f7fb;">

    <!-- LEFT SIDEBAR (Same as Dashboard) -->
    <left>
        <VBox spacing="20" prefWidth="220" style="-fx-background-color:#1e293b; -fx-padding:25;">
            <Label text="TaskFlow" style="-fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold;"/>
            <Separator/>
            <Button fx:id="dashboardBtn" text="Dashboard" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="projectsBtn" text="Projects" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="tasksBtn" text="Tasks" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="teamBtn" text="Team" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="reportsBtn" text="Reports" style="-fx-background-color:#334155; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Button fx:id="settingsBtn" text="Settings" style="-fx-background-color:transparent; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
            <Pane VBox.vgrow="ALWAYS"/>
            <Button fx:id="logoutBtn" text="Logout" style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-pref-width:180; -fx-cursor:hand;"/>
        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color:white; -fx-padding:15;">
            <Label text="Reports" style="-fx-font-size:20px; -fx-font-weight:bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label text="🔔" style="-fx-font-size:18px; -fx-cursor:hand;"/>
            <Label text="👤 John Doe" style="-fx-font-weight:bold; -fx-cursor:hand;"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="25" style="-fx-padding:30;">

            <!-- Report Controls -->
            <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;">
                
                <VBox spacing="5">
                    <Label text="Report Type" style="-fx-font-weight:bold;"/>
                    <ComboBox fx:id="reportTypeComboBox" prefWidth="200"/>
                </VBox>
                
                <VBox spacing="5">
                    <Label text="Start Date" style="-fx-font-weight:bold;"/>
                    <DatePicker fx:id="startDatePicker" prefWidth="150"/>
                </VBox>
                
                <VBox spacing="5">
                    <Label text="End Date" style="-fx-font-weight:bold;"/>
                    <DatePicker fx:id="endDatePicker" prefWidth="150"/>
                </VBox>
                
                <Button fx:id="generateReportBtn" text="Generate Report" 
                        style="-fx-background-color:#6366f1; -fx-text-fill:white; -fx-padding:10 20; -fx-background-radius:5; -fx-cursor:hand;"/>
            </HBox>

            <!-- Report Summary Cards -->
            <HBox spacing="20">
                <VBox spacing="10" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;" prefWidth="180">
                    <Label text="Total Tasks"/>
                    <Label fx:id="totalTasksLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:bold;"/>
                </VBox>
                
                <VBox spacing="10" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;" prefWidth="180">
                    <Label text="Completed"/>
                    <Label fx:id="completedTasksLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#22c55e;"/>
                </VBox>
                
                <VBox spacing="10" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;" prefWidth="180">
                    <Label text="Pending"/>
                    <Label fx:id="pendingTasksLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#f59e0b;"/>
                </VBox>
                
                <VBox spacing="10" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;" prefWidth="180">
                    <Label text="Overdue"/>
                    <Label fx:id="overdueTasksLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#ef4444;"/>
                </VBox>
            </HBox>

            <!-- Additional Stats -->
            <HBox spacing="20">
                <VBox spacing="10" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;" prefWidth="180">
                    <Label text="Projects"/>
                    <Label fx:id="totalProjectsLabel" text="0" style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#6366f1;"/>
                </VBox>
                
                <VBox spacing="10" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;" prefWidth="180">
                    <Label text="Team Members"/>
                    <Label fx:id="totalMembersLabel" text="0" style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#6366f1;"/>
                </VBox>
            </HBox>

            <!-- Placeholder for chart -->
            <VBox spacing="10" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:10;" prefHeight="200">
                <Label text="Report Chart" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                <Label text="Chart will be displayed here" style="-fx-text-fill:#64748b;" alignment="CENTER"/>
            </VBox>

        </VBox>
    </center>
    
</BorderPane>