<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.controllers.AddMemberDialogController"
      spacing="15" 
      style="-fx-padding:20; -fx-background-color:white;"
      prefWidth="650" prefHeight="550">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="projectTitleLabel" text="Manage Members" 
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1e293b;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="totalMembersLabel" text="Total Members: 0" 
               style="-fx-text-fill:#6366f1; -fx-font-weight:bold;"/>
    </HBox>
    
    <Separator/>
    
    <!-- Search Users Section -->
    <TitledPane text="Add New Members" expanded="true" style="-fx-background-color:#f8fafc;">
        <VBox spacing="15" style="-fx-padding:15;">
            
            <!-- Search Field -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Search:" style="-fx-font-weight:bold; -fx-min-width:60;"/>
                <TextField fx:id="searchUserField" promptText="Search by name or email..." 
                           HBox.hgrow="ALWAYS"
                           style="-fx-padding:8; -fx-background-radius:5; -fx-border-radius:5; -fx-border-color:#e2e8f0;"/>
                <Button fx:id="searchButton" text="🔍 Search" 
                        style="-fx-background-color:#6366f1; -fx-text-fill:white; -fx-padding:8 15; -fx-background-radius:5; -fx-cursor:hand;"/>
            </HBox>
            
            <!-- Available Users List -->
            <Label text="Available Users:" style="-fx-font-weight:bold; -fx-text-fill:#334155;"/>
            <ListView fx:id="availableUsersList" prefHeight="180" VBox.vgrow="ALWAYS"
                      style="-fx-background-radius:5; -fx-border-radius:5; -fx-border-color:#e2e8f0;">
                <!-- Placeholder when empty -->
                <placeholder>
                    <Label text="No users available" style="-fx-text-fill:#94a3b8;"/>
                </placeholder>
            </ListView>
            
            <!-- Role Selection and Add Button -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Role:" style="-fx-font-weight:bold; -fx-text-fill:#334155;"/>
                <ComboBox fx:id="roleComboBox" prefWidth="150"
                          style="-fx-background-radius:5; -fx-border-radius:5; -fx-border-color:#e2e8f0; -fx-padding:3;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button fx:id="addMemberButton" text="+ Add to Project" 
                        style="-fx-background-color:#22c55e; -fx-text-fill:white; -fx-padding:10 25; -fx-background-radius:5; -fx-font-weight:bold; -fx-cursor:hand;"
                        disable="true"/>
            </HBox>
            
        </VBox>
    </TitledPane>
    
    <Separator/>
    
    <!-- Current Members Section -->
    <TitledPane text="Current Project Members" expanded="true" style="-fx-background-color:#f8fafc;">
        <VBox spacing="10" style="-fx-padding:15;">
            
            <TableView fx:id="currentMembersTable" prefHeight="200" VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="No members in this project" style="-fx-text-fill:#94a3b8;"/>
                </placeholder>
                <columns>
                    <TableColumn fx:id="memberNameColumn" text="Name" prefWidth="200"/>
                    <TableColumn fx:id="memberEmailColumn" text="Email" prefWidth="250"/>
                    <TableColumn fx:id="memberRoleColumn" text="Role" prefWidth="100"/>
                    <TableColumn fx:id="memberActionColumn" text="" prefWidth="60"/>
                </columns>
            </TableView>
            
        </VBox>
    </TitledPane>
    
    <Pane VBox.vgrow="ALWAYS"/>
    
    <!-- Footer Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="closeButton" text="Close" 
                style="-fx-background-color:#f1f5f9; -fx-text-fill:#334155; -fx-padding:10 30; -fx-background-radius:5; -fx-font-weight:bold; -fx-cursor:hand;"/>
    </HBox>
    
</VBox>