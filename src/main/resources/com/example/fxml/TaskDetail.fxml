<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.frontend.controllers.TaskDetailController"
            style="-fx-background-color:#f5f7fb;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" 
              style="-fx-background-color:white; -fx-padding:15; -fx-border-color:#e2e8f0; -fx-border-width:0 0 1 0;">
            
            <Button fx:id="backButton" text="← Back"/>
            <Label text="Task Details"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button fx:id="refreshButton" text="↻ Refresh"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="20" style="-fx-padding:30;">

                <HBox spacing="10">
                    <Label text="Project:"/>
                    <Label fx:id="taskProjectLabel"/>
                </HBox>

                <Label fx:id="taskTitleLabel"/>

                <HBox spacing="10">
                    <Label text="Assignee:"/>
                    <Label fx:id="assigneeLabel" text="Unassigned"/>
                    <Label text="Due:"/>
                    <Label fx:id="dueDateLabel" text="No deadline"/>
                </HBox>

                <GridPane hgap="20" vgap="10">
                    <ComboBox fx:id="statusComboBox"/>
                    <ComboBox fx:id="priorityComboBox"/>
                    <ComboBox fx:id="assigneeComboBox" promptText="Assign member"/>
                </GridPane>

                <TextArea fx:id="descriptionArea"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="commentCountLabel" text="Comments (0)"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="sortCommentsCombo" prefWidth="150"/>
                </HBox>

                <ListView fx:id="commentsListView" prefHeight="260"/>

                <VBox spacing="8">
                    <TextArea fx:id="newCommentArea" prefRowCount="3" wrapText="true"
                              promptText="Write a comment..."/>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button fx:id="cancelCommentButton" text="Cancel"/>
                        <Button fx:id="postCommentButton" text="Post Comment"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>